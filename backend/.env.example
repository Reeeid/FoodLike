PORT=8080

# docker-composeで動かす場合はmysqlサービス名。ローカルでgo run直叩きなら localhost
DB_HOST=mysql
DB_PORT=3306
DB_USER=foodlike
DB_PASSWORD=foodlike
DB_NAME=foodlike
DB_TLS=false
# Firebase Admin用プロジェクトID（空ならモック認証: X-Member-IDで動く）
FIREBASE_PROJECT_ID=

# HotPepper グルメサーチAPIキー（空ならモックのお店データで動く）
# 無料登録: https://webservice.recruit.co.jp/
HOTPEPPER_API_KEY=

# Gemini(AI検索の回答生成)。空なら定型文で動く。失敗時も定型文へ自動フォールバック
# 取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 使うモデル（省略時 gemini-2.5-flash-lite）。無料枠で動く: gemini-2.5-flash-lite,
# gemini-3.1-flash-lite。※gemini-3.5-flashは課金枠(429)、gemini-2.5-flashは提供終了(404)
# GEMINI_MODEL=gemini-2.5-flash-lite

# Gemini自身のGoogle検索(grounding)を使うか。既定true。課金枠が要るのでfalse推奨
# （TAVILY_API_KEYを入れると自動でfalseになる）
# GEMINI_GROUNDING=false

# Tavily(LLM向け検索API・無料枠1,000検索/月)。設定するとAIチャット検索の
# 実店舗の根拠をTavilyで取り、Geminiのgrounding課金を回避する
# 取得: https://tavily.com/
TAVILY_API_KEY=

# TiDB Cloud等のTLS必須MySQLに繋ぐときだけ true（ローカルMySQLは未設定）
# DB_TLS=true

# tavily api key
TAVILY_API_KEY=tvly-xxxxxxxx
